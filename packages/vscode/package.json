{
    "name": "git-gud-vscode",
    "publisher": "git-gud",
    "version": "0.1.0",
    "main": "dist/extension.js",
    "engines": {
        "vscode": "^1.85.0"
    },
    "activationEvents": [
        "onStartupFinished"
    ],
    "contributes": {
        "commands": [
            {
                "command": "gitgud.showStatus",
                "title": "Show Status",
                "category": "Git Gud"
            },
            {
                "command": "gitgud.showDashboard",
                "title": "Show Dashboard",
                "category": "Git Gud"
            },
            {
                "command": "gitgud.resetStats",
                "title": "Reset Stats",
                "category": "Git Gud"
            },
            {
                "command": "gitgud.toggleSound",
                "title": "Toggle Sound",
                "category": "Git Gud"
            },
            {
                "command": "gitgud.showProfile",
                "title": "Show Profile",
                "category": "Git Gud"
            },
            {
                "command": "gitgud.testRoast",
                "title": "Test Roast (Demo)",
                "category": "Git Gud"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "gitgud-sidebar",
                    "title": "Git Gud",
                    "icon": "$(flame)"
                }
            ]
        },
        "views": {
            "gitgud-sidebar": [
                {
                    "type": "webview",
                    "id": "gitgud-dashboard",
                    "name": "Dashboard"
                }
            ]
        },
        "configuration": {
            "title": "Git Gud",
            "properties": {
                "gitgud.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable Git Gud extension"
                },
                "gitgud.soundEnabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable sound effects"
                },
                "gitgud.notificationsEnabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show notification popups"
                },
                "gitgud.roastIntensity": {
                    "type": "string",
                    "enum": ["mild", "medium", "savage"],
                    "default": "medium",
                    "description": "Roast severity level"
                }
            }
        }
    },
    "scripts": {
        "build": "tsc",
        "vscode:prepublish": "npm run build",
        "package": "npx @vscode/vsce package --no-dependencies"
    },
    "dependencies": {
        "@git-gud/core": "*"
    },
    "devDependencies": {
        "typescript": "^5.0.0",
        "@types/vscode": "^1.85.0",
        "@types/node": "^20.0.0"
    }
}
