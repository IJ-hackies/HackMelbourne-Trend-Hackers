{
  "name": "git-gud-vscode",
  "displayName": "Git Gud",
  "description": "Competitive Git coaching with esports-style roasts",
  "version": "0.1.0",
  "publisher": "git-gud",
  "license": "MIT",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "keywords": [
    "git",
    "gamification",
    "productivity",
    "roasts",
    "esports",
    "leaderboard"
  ],
  "categories": [
    "Other",
    "Machine Learning",
    "Visualization"
  ],
  "engines": { "vscode": "^1.85.0" },
  "main": "dist/extension.js",
  "activationEvents": ["workspaceContains:.git", "onView:gitgud.sidebar"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "gitgud", "title": "Git Gud", "icon": "$(flame)" }
      ]
    },
    "views": {
      "gitgud": [
        { "type": "webview", "id": "gitgud.sidebar", "name": "Dashboard" }
      ]
    },
    "commands": [
      { "command": "gitgud.showDashboard", "title": "Show Dashboard", "category": "Git Gud" },
      { "command": "gitgud.resetStats", "title": "Reset Stats", "category": "Git Gud" },
      { "command": "gitgud.setApiKey", "title": "Set API Key", "category": "Git Gud" },
      { "command": "gitgud.runDemo", "title": "Run Demo", "category": "Git Gud" },
      { "command": "gitgud.exportRankCard", "title": "Export Rank Card", "category": "Git Gud" },
      { "command": "gitgud.weeklyReport", "title": "Weekly Hygiene Report", "category": "Git Gud" },
      { "command": "gitgud.shareToTeam", "title": "Share Stats to Team", "category": "Git Gud" }
    ],
    "configuration": {
      "title": "Git Gud",
      "properties": {
        "gitgud.enabled": { "type": "boolean", "default": true, "description": "Enable Git Gud monitoring." },
        "gitgud.aiProvider": { "type": "string", "default": "gemini", "enum": ["gemini", "claude", "openai", "xai", "ollama"], "description": "AI provider for roast generation." },
        "gitgud.ollamaApiKey": { "type": "string", "default": "", "description": "API key for Ollama AI roasts." },
        "gitgud.ollamaModel": { "type": "string", "default": "", "enum": ["", "deepseek-v4-flash:cloud", "deepseek-v4-pro:cloud", "kimi-k2.6:cloud", "glm-5.1:cloud", "gemma4:cloud", "qwen3.5:cloud"], "description": "Ollama model (default: deepseek-v4-flash:cloud)." },
        "gitgud.ollamaBaseUrl": { "type": "string", "default": "", "description": "Ollama API base URL." },
        "gitgud.geminiApiKey": { "type": "string", "default": "", "description": "Gemini API key." },
        "gitgud.geminiModel": { "type": "string", "default": "gemini-2.5-flash", "enum": ["gemini-2.5-flash", "gemini-2.5-pro", "gemini-2.5-flash-lite"], "description": "Gemini model." },
        "gitgud.claudeApiKey": { "type": "string", "default": "", "description": "Anthropic Claude API key." },
        "gitgud.claudeModel": { "type": "string", "default": "claude-sonnet-4-6", "enum": ["claude-opus-4-7", "claude-sonnet-4-6", "claude-haiku-4-5"], "description": "Claude model." },
        "gitgud.openaiApiKey": { "type": "string", "default": "", "description": "OpenAI (ChatGPT) API key." },
        "gitgud.openaiModel": { "type": "string", "default": "gpt-4o-mini", "enum": ["gpt-5", "gpt-4o", "gpt-4o-mini", "o1-mini"], "description": "OpenAI model." },
        "gitgud.xaiApiKey": { "type": "string", "default": "", "description": "xAI (Grok) API key." },
        "gitgud.xaiModel": { "type": "string", "default": "grok-3-mini", "enum": ["grok-4", "grok-3", "grok-3-mini"], "description": "Grok model." },
        "gitgud.voiceEnabled": { "type": "boolean", "default": false, "description": "Speak savage roasts and rank-ups out loud (browser SpeechSynthesis)." },
        "gitgud.roastIntensity": { "type": "string", "enum": ["mild", "medium", "savage"], "default": "savage", "description": "Roast severity level." },
        "gitgud.notificationsEnabled": { "type": "boolean", "default": true, "description": "Show notification popups." },
        "gitgud.teamCode": { "type": "string", "default": "", "description": "Team code for shared leaderboard." },
        "gitgud.syncUrl": { "type": "string", "default": "http://localhost:3000/api/sync", "description": "URL to sync stats to web leaderboard." },
        "gitgud.commitMessageStyle": { "type": "string", "default": "clean", "enum": ["clean", "savage"], "description": "Tone for AI-generated commit messages: clean (Conventional Commits) or savage (toxic-coach roast)." }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {
    "@git-gud/core": "*"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5"
  }
}
