{
  "name": "git-gud",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:core": "npm run build --workspace=@git-gud/core",
    "build:ext": "npm run build --workspace=git-gud-vscode",
    "dev:web": "npm run dev --workspace=@git-gud/web",
    "dev:ext": "npm run watch --workspace=git-gud-vscode"
  }
}
